generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id         String      @id @default(uuid())
  locale     String      @default("fr")
  storyId    String
  status     String      @default("created") // created | uploaded | processing | done | failed
  createdAt  DateTime    @default(now())
  previewKey String? // final composited page — one per session, all characters combined
  characters Character[]
}

model Character {
  id          String  @id @default(uuid())
  sessionId   String
  session     Session @relation(fields: [sessionId], references: [id])
  slot        String // matches a face region in the session's template, e.g. "child_1"
  childName   String
  rawKey      String? // R2 key, original upload
  noBgKey     String? // no-bg version of the *stylized portrait* (not the raw upload)
  skinToneHex String? // sampled from the raw upload's face region
  portraitKey String? // illustrated portrait, from the raw upload
  jobId       String? // BullMQ job id for status lookup

  @@unique([sessionId, slot])
}
