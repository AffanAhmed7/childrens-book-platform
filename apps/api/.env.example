# Copy to .env (same directory) and fill in. NEVER commit the filled-in .env.
# Service-by-service setup notes are in ../../PROJECT_PLAN.md §9 — but read the
# banner at the top of that file first: it is a historical record, and the
# remove.bg / portrait-model keys it lists are no longer used.
#
# The demo harness (npm run demo:web, npm run personalize) needs ONLY
# REPLICATE_API_TOKEN — no database, no Redis, no storage.

# --- Database: PostgreSQL (Neon free tier) ---
# Required to run Day 1 (session storage) and `prisma migrate dev`.
# Recommended: append "&connect_timeout=30" — Neon's serverless compute can
# cold-start after idling, and Prisma's default connect timeout is too short
# for that, surfacing as an intermittent "Can't reach database server" error.
DATABASE_URL=

# --- Object storage: Cloudflare R2 (S3-compatible) ---
# Required to run Day 1 (presigned photo upload).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# --- Queue: Redis (Upstash free tier) ---
# Not needed until Day 2 (BullMQ pipeline). Must use "rediss://" (TLS), not
# "redis://" — Upstash requires TLS; the plain scheme connects then resets.
REDIS_URL=

# --- The image engine: Replicate ---
# Required by every paid stage. Three models run per character, per page:
#   google/nano-banana        repaint   ~$0.039  <- dominates COST
#   InsightFace inswapper     swap      ~$0.006  <- dominates LATENCY (~55-90s)
#   CodeFormer                restore   small
# Budget roughly $0.045 per page per character, and ~90-170s wall time. A full
# 3-scene single-character demo run is about 15 cents.
#
# Pay-per-run, no subscription. Get a token at replicate.com/account/api-tokens
# after adding a payment method — whoever's funding this can create the token
# and hand it over, without sharing the account itself.
#
# LICENSING: inswapper is published for non-commercial/research use only.
# A commercial licence is required before this ships as a paid product — see
# "Known state" in ./README.md.
REPLICATE_API_TOKEN=

# --- Swap backend ---
# "replicate" (default) uses the hosted model. "local" points at
# services/faceswap, which runs the SAME inswapper model with the weights
# resident in memory instead of reloaded on every call.
#
# The hosted call bills ~60 seconds of CPU for under a second of real inference
# — the rest is cold start. Self-hosted, the swap stage goes from ~55-90s to
# ~3.5s (measured), which takes a whole page from ~90-170s to ~15-25s.
#
# Requires the service to be running and its weights present; see
# services/faceswap/README.md. Leave unset to keep the hosted behaviour.
SWAP_BACKEND=replicate
SWAP_LOCAL_URL=http://127.0.0.1:5175

# --- App config ---
# Comma-separated allowed origins for CORS
CORS_ORIGIN=http://localhost:3000
PORT=3001
