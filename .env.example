# Copy to .env and fill in. NEVER commit the filled-in .env.
# See PROJECT_PLAN.md §9 for how to provision each service (free tiers).

# --- Database: PostgreSQL (Neon free tier) ---
DATABASE_URL=

# --- Queue: Redis (Upstash free tier) ---
REDIS_URL=

# --- Object storage: Cloudflare R2 (S3-compatible) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# --- Background removal: remove.bg ---
REMOVEBG_API_KEY=

# --- Portrait generation: Replicate ---
REPLICATE_API_TOKEN=
REPLICATE_MODEL_VERSION=

# --- App config ---
# Comma-separated allowed origins for CORS (the web app URL)
CORS_ORIGIN=http://localhost:3000
# Public base URL of the API (used by the web app)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
PORT=3001
